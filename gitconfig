{{#if (and GIT_NAME GIT_EMAIL)}}
[user]
    name = {{ GIT_NAME }}
    email = {{ GIT_EMAIL }}

[credential]
    helper = store

{{/if}}

[core]
    {{#if (eq dotter.os "windows")}}
    symlinks = true
    autocrlf = true
    {{else}}
    autocrlf = input
    {{/if}}
    editor = vim
    quotepath = false
    pager = delta
    fileMode = false

[interactive]
    diffFilter = delta --color-only

[delta]
    side-by-side = true
    navigate = true # use n and N to move between diff sections
    dark = true     # or light = true, or omit for auto-detection

[merge]
    conflictStyle = zdiff3  # for delta

[color]
    ui = auto

[advice]
    ignoredHook = false

[help]
    autocorrect = 20

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph --decorate --all

[push]
    autoSetupRemote = true
    default = simple

[pull]
    rebase = true

